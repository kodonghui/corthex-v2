# n8n Docker Environment Variables
# Copy to .env and fill in values before deployment
#
# Generate encryption key: openssl rand -hex 32

# REQUIRED: AES-256-GCM credential encryption key (N8N-SEC-7)
N8N_ENCRYPTION_KEY=

# CORTHEX server port (for n8n → CORTHEX webhook callbacks)
CORTHEX_PORT=3000

# Timezone
TZ=Asia/Seoul
