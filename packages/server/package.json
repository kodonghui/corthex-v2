{
  "name": "@corthex/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "bun test src/__tests__/",
    "test:unit": "bun test src/__tests__/unit/",
    "test:api": "bun test src/__tests__/api/",
    "test:sdk": "bun test src/__tests__/sdk/",
    "mcp:sketchvibe": "bun run src/mcp/sketchvibe-mcp.ts",
    "ab-test": "bun run scripts/ab-quality-test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.72",
    "@anthropic-ai/sdk": "0.78.0",
    "@aws-sdk/client-s3": "3.717.0",
    "@corthex/shared": "workspace:*",
    "@google/generative-ai": "0.24.1",
    "@hono/zod-validator": "0.5.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@neondatabase/serverless": "1.0.2",
    "@zapier/secret-scrubber": "^1.1.6",
    "croner": "^10.0.1",
    "drizzle-orm": "0.39.3",
    "hono": "4.12.3",
    "hono-rate-limiter": "0.5.3",
    "js-yaml": "^4.1.1",
    "marked": "12.0.0",
    "openai": "^6.27.0",
    "p-queue": "8.0.1",
    "pgvector": "0.2.1",
    "pino": "10.3.1",
    "postgres": "3.4.8",
    "puppeteer": "22.15.0",
    "web-push": "^3.6.7",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@types/js-yaml": "^4.0.9",
    "@types/web-push": "^3.6.4",
    "bun-types": "1.3.10",
    "drizzle-kit": "0.30.6",
    "typescript": "^5.7",
    "zod-to-json-schema": "^3.25.1"
  }
}
