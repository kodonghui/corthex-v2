{
  "name": "@corthex/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@corthex/shared": "workspace:*",
    "hono": "^4",
    "drizzle-orm": "^0.39",
    "postgres": "^3.4",
    "@hono/zod-validator": "^0.5",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7",
    "drizzle-kit": "^0.30"
  }
}
