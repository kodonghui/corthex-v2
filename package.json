{
  "name": "corthex-v2",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "dev:server": "bun run --cwd packages/server dev",
    "dev:app": "bun run --cwd packages/app dev",
    "dev:admin": "bun run --cwd packages/admin dev",
    "db:generate": "bun run --cwd packages/server db:generate",
    "db:migrate": "bun run --cwd packages/server db:migrate",
    "test": "turbo test",
    "test:unit": "turbo test:unit"
  },
  "packageManager": "bun@1.3.10",
  "devDependencies": {
    "@types/dotenv": "^8.2.3",
    "puppeteer-core": "^24.40.0",
    "turbo": "^2.8.21",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@smithy/config-resolver": "^4.4.13",
    "esbuild": "^0.27.4",
    "hono": "^4.12.9",
    "picomatch": "^4.0.4"
  },
  "overrides": {
    "fast-xml-parser": ">=4.5.4",
    "path-to-regexp": ">=8.4.0"
  }
}
