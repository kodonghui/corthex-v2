{
  "name": "corthex-v2",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --cwd packages/app dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "dev:server": "bun run --cwd packages/server dev",
    "dev:app": "bun run --cwd packages/app dev",
    "dev:admin": "bun run --cwd packages/admin dev",
    "db:generate": "bun run --cwd packages/server db:generate",
    "db:migrate": "bun run --cwd packages/server db:migrate",
    "test": "turbo test",
    "test:unit": "turbo test:unit"
  },
  "packageManager": "bun@1.3.10",
  "devDependencies": {
    "typescript": "^5.7"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "vite": "^7.3.1"
  }
}
