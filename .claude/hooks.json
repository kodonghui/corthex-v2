{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/corthex-v2/.claude/hooks/cleanup.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/corthex-v2/.claude/hooks/cleanup.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/ecc/hooks/session-start.js",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/corthex-v2/.claude/hooks/pre-commit-tsc.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "/home/ubuntu/corthex-v2/.claude/hooks/party-log-verify.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/party-mode-compliance.js",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/ecc/hooks/doc-file-warning.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/ecc/hooks/suggest-compact.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/ecc/hooks/governance-capture.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/ecc/hooks/pre-compact.js",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/corthex-v2/.claude/hooks/post-compact-save.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/ecc/hooks/post-edit-console-warn.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/ecc/hooks/governance-capture.js",
