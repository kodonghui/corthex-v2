          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/corthex-v2/.claude/hooks/session-end-reminder.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/ecc/hooks/session-end.js",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/ecc/hooks/cost-tracker.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/ubuntu/corthex-v2/.claude/hooks/ecc/hooks/evaluate-session.js",
